{
  "name": "ai-chat-database",
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "dev:electron": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"sleep 3 && electron .\"",
    "dev:chroma": "concurrently \"npm run chroma\" \"npm run dev\"",
    "chroma": "npx chroma run --path ./data/chroma",
    "build": "tsc -b && vite build",
    "build:electron": "npm run build && electron-builder",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "electron": "electron ."
  },
  "dependencies": {
    "@tdesign-react/aigc": "^0.1.0-alpha.1",
    "@tdesign-react/chat": "^1.0.2",
    "@tencent-ai/agent-sdk": "^0.3.43",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^3.6.0",
    "chromadb": "^1.9.2",
    "chromadb-default-embed": "^2.13.2",
    "express": "^4.18.2",
    "glob": "^10.3.10",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.563.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0",
    "tdesign-icons-react": "^0.5.0",
    "tdesign-react": "^1.12.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "less": "^4.3.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vite": "^5.0.10"
  },
  "build": {
    "appId": "com.ai-chat-database.app",
    "productName": "AI知识库助手",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "data/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
